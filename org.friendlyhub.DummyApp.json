{
  "app-id": "org.friendlyhub.DummyApp",
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/dummyapp/cargo"
    }
  },
  "command": "dummyapp",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "build-commands": [
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo --offline build --release --verbose",
        "install -Dm755 target/release/dummyapp /app/bin/dummyapp",
        "install -Dm644 org.friendlyhub.DummyApp.metainfo.xml /app/share/metainfo/org.friendlyhub.DummyApp.metainfo.xml",
        "install -Dm644 org.friendlyhub.DummyApp.desktop /app/share/applications/org.friendlyhub.DummyApp.desktop",
        "install -Dm644 org.friendlyhub.DummyApp.svg /app/share/icons/hicolor/scalable/apps/org.friendlyhub.DummyApp.svg"
      ],
      "buildsystem": "simple",
      "name": "dummyapp",
      "sources": [
        {
          "tag": "v0.1.0",
          "type": "git",
          "url": "https://github.com/icemaltacode/dummyapp.git"
        },
        "cargo-sources.json"
      ]
    }
  ],
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ]
}